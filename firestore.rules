rules_version = '2';

// Bulevini güvenlik kuralları — 15 Tem 2026
// İlkeler: yorumlar herkese açık okunur (SEO); yazma = girişli + e-postası doğrulanmış;
// kimse başkası adına yazamaz; oylar gizli alt koleksiyonda (kim oyladı görünmez, sayaç görünür);
// puan sayaçları elle şişirilemez; radar kayıtları ve kullanıcı belgeleri sadece sahibine.
service cloud.firestore {
  match /databases/{database}/documents {

    match /yorumlar/{yorumId} {
      // Bina karneleri ve deneyimler herkese açık — SEO ve ziyaretçi deneyimi
      allow read: if true;

      // Mühür basma: doğrulanmış hesap; kimlik ya kendi ya bilinçli anonim (null);
      // oy sayaçları sıfır başlamak zorunda (şişirme kapalı)
      allow create: if request.auth != null
        && request.auth.token.email_verified == true
        && (request.resource.data.kullanici_id == request.auth.uid
            || request.resource.data.kullanici_id == null)
        && request.resource.data.get('faydali_sayisi', 0) == 0
        && request.resource.data.get('faydasiz_sayisi', 0) == 0;

      // Silme: sadece sahibi (anonim mühür silinemez — kalıcılık bilinçli)
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.kullanici_id;

      // Güncelleme SADECE oy sayaçları için ve toplamda +1;
      // aynı pakette kişinin kendi oy belgesi de yazılmış olmalı (getAfter)
      allow update: if request.auth != null
        && request.auth.token.email_verified == true
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['faydali_sayisi', 'faydasiz_sayisi'])
        && (request.resource.data.get('faydali_sayisi', 0) - resource.data.get('faydali_sayisi', 0))
         + (request.resource.data.get('faydasiz_sayisi', 0) - resource.data.get('faydasiz_sayisi', 0)) == 1
        && getAfter(/databases/$(database)/documents/yorumlar/$(yorumId)/oylar/$(request.auth.uid)).data.tip is string;

      // Oylar — gizli kasa: herkes yalnız KENDİ oyunu okuyabilir/oluşturabilir.
      // Belge kimliği = kullanıcı kimliği → kişi başı 1 oy fiziken garanti (ikinci create patlar).
      match /oylar/{oyId} {
        allow read: if request.auth != null && request.auth.uid == oyId;
        allow create: if request.auth != null
          && request.auth.uid == oyId
          && request.resource.data.tip in ['faydali', 'faydasiz'];
        // güncelleme/silme yok — oy kalıcı
      }
    }

    match /takipler/{takipId} {
      // Radar tamamen kişiseldir: kimin neyi izlediği kimseye görünmez
      allow read: if request.auth != null && request.auth.uid == resource.data.kullanici_id;
      allow create: if request.auth != null
        && request.auth.token.email_verified == true
        && request.resource.data.kullanici_id == request.auth.uid;
      allow delete: if request.auth != null && request.auth.uid == resource.data.kullanici_id;
    }

    match /kullanicilar/{userId} {
      // Sadece kendi belgen — okuma dahil (yarın hassas veri girerse hazır)
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /sikayetler/{sikayetId} {
      // Şikayet: doğrulanmış kullanıcı kendi adına oluşturur; okuma yok (sadece yönetici konsoldan)
      allow create: if request.auth != null
        && request.auth.token.email_verified == true
        && request.resource.data.kullanici_id == request.auth.uid;
    }
  }
}
